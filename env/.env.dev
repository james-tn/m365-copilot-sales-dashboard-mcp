# Microsoft 365 Agents Toolkit environment (dev).
# This file holds non-secret configuration and is safe to commit.

TEAMSFX_ENV=dev
APP_NAME_SUFFIX=

# Public HTTPS URL of the MCP server's /mcp endpoint.
# Set this to your dev tunnel (or Azure) URL before packaging/provisioning, e.g.:
#   MCP_ENDPOINT_URL=https://<your-tunnel>-3978.<region>.devtunnels.ms/mcp
MCP_ENDPOINT_URL=

# A stable GUID for your app. Generate one with:
#   python3 -c "import uuid; print(uuid.uuid4())"
TEAMS_APP_ID=

# Populated by provisioning.
M365_TITLE_ID=
M365_APP_ID=
